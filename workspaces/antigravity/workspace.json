{
  "friendly_name": "Antigravity",
  "description": "Google Antigravity Hub desktop application. Cloud-native workspace management built by Google.",
  "image_src": "https://brandlogos.net/wp-content/uploads/2025/12/google_antigravity-logo_brandlogos.net_qu4jc-512x472.png",
  "architecture": ["amd64"],
  "compatibility": [
    {
      "version": "1.19.x",
      "image": "ghcr.io/hoomanjavadpoor/kasm-antigravity:rolling-daily",
      "uncompressed_size_mb": 1900,
      "available_tags": ["rolling-daily", "latest"]
    }
  ],
  "categories": ["Development"],
  "docker_registry": "https://ghcr.io",
  "run_config": {
    "hostname": "kasm"
  },
  "exec_config": {
    "go": {
      "cmd": "bash -c '/dockerstartup/custom_startup.sh --go --url \"$KASM_URL\"'"
    },
    "assign": {
      "cmd": "bash -c '/dockerstartup/custom_startup.sh --assign --url \"$KASM_URL\"'"
    }
  },
  "cores": 2,
  "memory": 2768,
  "gpu_count": 0,
  "cpu_allocation_method": "Inherit"
}
