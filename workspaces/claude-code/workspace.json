{
  "friendly_name": "Claude Code",
  "description": "Anthropic Claude Code CLI in an xterm terminal. Run 'claude' to start. Requires ANTHROPIC_API_KEY at runtime.",
  "image_src": "claude-code.svg",
  "architecture": ["amd64"],
  "compatibility": [
    {
      "version": "1.19.x",
      "image": "ghcr.io/hoomanjavadpoor/kasm-claude-code:rolling-daily",
      "uncompressed_size_mb": 2200,
      "available_tags": ["rolling-daily", "latest"]
    }
  ],
  "categories": ["Development", "AI"],
  "docker_registry": "https://ghcr.io",
  "run_config": {
    "hostname": "kasm"
  },
  "exec_config": {
    "go": {
      "cmd": "bash -c '/dockerstartup/custom_startup.sh --go --url \"$KASM_URL\"'"
    },
    "assign": {
      "cmd": "bash -c '/dockerstartup/custom_startup.sh --assign --url \"$KASM_URL\"'"
    }
  },
  "cores": 2,
  "memory": 4096,
  "gpu_count": 0,
  "cpu_allocation_method": "Inherit"
}
