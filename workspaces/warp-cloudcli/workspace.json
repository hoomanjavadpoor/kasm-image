{
  "friendly_name": "Warp + Cloud CLIs",
  "description": "Warp Terminal with Azure CLI, AWS CLI, Google Cloud CLI, GitHub CLI, and kubectl. A modern terminal for cloud operations.",
  "image_src": "https://github.com/warpdotdev.png?size=200",
  "architecture": ["amd64"],
  "compatibility": [
    {
      "version": "1.19.x",
      "image": "ghcr.io/hoomanjavadpoor/kasm-warp-cloudcli:rolling-daily",
      "uncompressed_size_mb": 4200,
      "available_tags": ["rolling-daily", "latest"]
    }
  ],
  "categories": ["Development", "DevOps"],
  "docker_registry": "https://ghcr.io",
  "run_config": {
    "hostname": "kasm"
  },
  "exec_config": {
    "go": {
      "cmd": "bash -c '/dockerstartup/custom_startup.sh --go --url \"$KASM_URL\"'"
    },
    "assign": {
      "cmd": "bash -c '/dockerstartup/custom_startup.sh --assign --url \"$KASM_URL\"'"
    }
  },
  "cores": 2,
  "memory": 4096,
  "gpu_count": 0,
  "cpu_allocation_method": "Inherit"
}
