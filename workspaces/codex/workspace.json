{
  "friendly_name": "OpenAI Codex CLI",
  "description": "OpenAI Codex CLI coding assistant in a terminal workspace, with GitHub CLI pre-installed. Requires OPENAI_API_KEY at runtime.",
  "image_src": "https://zonalogo.com/assets/codex-logo.webp?w=768",
  "architecture": ["amd64"],
  "compatibility": [
    {
      "version": "1.19.x",
      "image": "ghcr.io/hoomanjavadpoor/kasm-codex:rolling-daily",
      "uncompressed_size_mb": 2200,
      "available_tags": ["rolling-daily", "latest"]
    }
  ],
  "categories": ["Development", "AI"],
  "docker_registry": "https://ghcr.io",
  "run_config": {
    "hostname": "kasm"
  },
  "exec_config": {
    "go": {
      "cmd": "bash -c '/dockerstartup/custom_startup.sh --go --url \"$KASM_URL\"'"
    },
    "assign": {
      "cmd": "bash -c '/dockerstartup/custom_startup.sh --assign --url \"$KASM_URL\"'"
    }
  },
  "cores": 2,
  "memory": 4096,
  "gpu_count": 0,
  "cpu_allocation_method": "Inherit"
}
