{
  "friendly_name": "AnyDesk",
  "description": "AnyDesk remote desktop client. Access and control other machines securely from within your Kasm session.",
  "image_src": "anydesk.svg",
  "architecture": ["amd64"],
  "compatibility": [
    {
      "version": "1.19.x",
      "image": "ghcr.io/hoomanjavadpoor/kasm-anydesk:rolling-daily",
      "uncompressed_size_mb": 1800,
      "available_tags": ["rolling-daily", "latest"]
    }
  ],
  "categories": ["Remote Access"],
  "docker_registry": "https://ghcr.io",
  "run_config": {
    "hostname": "kasm"
  },
  "exec_config": {
    "go": {
      "cmd": "bash -c '/dockerstartup/custom_startup.sh --go --url \"$KASM_URL\"'"
    },
    "assign": {
      "cmd": "bash -c '/dockerstartup/custom_startup.sh --assign --url \"$KASM_URL\"'"
    }
  },
  "cores": 2,
  "memory": 2768,
  "gpu_count": 0,
  "cpu_allocation_method": "Inherit"
}
