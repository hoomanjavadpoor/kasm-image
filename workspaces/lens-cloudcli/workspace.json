{
  "friendly_name": "Lens + Cloud CLIs",
  "description": "Lens Desktop Kubernetes IDE with kubectl, Helm, Azure CLI, AWS CLI, Google Cloud CLI, and GitHub CLI. NOTE: Lens is no longer free — a paid Lens subscription is required. See https://lenshq.io/legal/tos.",
  "image_src": "lens-cloudcli.svg",
  "architecture": ["amd64"],
  "compatibility": [
    {
      "version": "1.19.x",
      "image": "ghcr.io/hoomanjavadpoor/kasm-lens-cloudcli:rolling-daily",
      "uncompressed_size_mb": 4200,
      "available_tags": ["rolling-daily", "latest"]
    }
  ],
  "categories": ["Development", "DevOps"],
  "docker_registry": "https://ghcr.io",
  "run_config": {
    "hostname": "kasm"
  },
  "exec_config": {
    "go": {
      "cmd": "bash -c '/dockerstartup/custom_startup.sh --go --url \"$KASM_URL\"'"
    },
    "assign": {
      "cmd": "bash -c '/dockerstartup/custom_startup.sh --assign --url \"$KASM_URL\"'"
    }
  },
  "cores": 2,
  "memory": 4096,
  "gpu_count": 0,
  "cpu_allocation_method": "Inherit"
}
