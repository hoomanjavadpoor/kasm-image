{
  "friendly_name": "FreeLens + Cloud CLIs",
  "description": "FreeLens (open-source Kubernetes IDE) with kubectl, Helm, Azure CLI, AWS CLI, Google Cloud CLI, and GitHub CLI. Single-app workspace, always up to date via rolling-daily builds.",
  "image_src": "https://raw.githubusercontent.com/freelensapp/freelens/efe5985860dea43be40db74edea9408e2f4900b6/packages/ui-components/icon/assets/logo-lens.svg",
  "architecture": ["amd64"],
  "compatibility": [
    {
      "version": "1.19.x",
      "image": "ghcr.io/hoomanjavadpoor/kasm-freelens-cloudcli:rolling-daily",
      "uncompressed_size_mb": 4000,
      "available_tags": ["rolling-daily", "latest"]
    }
  ],
  "categories": ["Development", "DevOps"],
  "docker_registry": "https://ghcr.io",
  "run_config": {
    "hostname": "kasm"
  },
  "exec_config": {
    "go": {
      "cmd": "bash -c '/dockerstartup/custom_startup.sh --go --url \"$KASM_URL\"'"
    },
    "assign": {
      "cmd": "bash -c '/dockerstartup/custom_startup.sh --assign --url \"$KASM_URL\"'"
    }
  },
  "cores": 2,
  "memory": 4096,
  "gpu_count": 0,
  "cpu_allocation_method": "Inherit"
}
